# Whoop OAuth (from developer.whoop.com)
WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:3000/auth/whoop/callback

# Security
ENCRYPTION_SECRET=           # Used to derive AES-256 key via PBKDF2 for token encryption (min 32 chars)
MCP_BEARER_TOKEN=            # Static bearer token for direct MCP access (curl, scripts)

# MCP OAuth (for Claude Custom Connectors)
MCP_OAUTH_CLIENT_ID=         # Client ID entered in Claude Custom Connector settings
MCP_OAUTH_CLIENT_SECRET=     # Client Secret entered in Claude Custom Connector settings

# Server
PORT=3000
NODE_ENV=development
